FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml ./
COPY school_status_api ./school_status_api

RUN pip install --no-cache-dir .

EXPOSE 8000

CMD ["uvicorn", "school_status_api.runtime:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers", "--forwarded-allow-ips", "*"]
