DATABASE_URL=postgresql+psycopg://school_status:change-me@postgres:5432/school_status
CLIENTS_CONFIG_PATH=/app/config/clients.yml
TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12
MONGO_URI=mongodb://user:password@mongo.example.edu.cn:27017/?authSource=admin
MONGO_DATABASE=source_database
MONGO_COLLECTION=source_collection
SYNC_HOUR=3
SYNC_MINUTE=0
SYNC_BATCH_SIZE=1000
SYNC_TIMEZONE=Asia/Shanghai
RUN_INITIAL_SYNC=false
POSTGRES_DB=school_status
POSTGRES_USER=school_status
POSTGRES_PASSWORD=change-me
